   <FilesMatch \.php$>
     # Do not allow PHP scripts to be cached unless they explicitly send cache
     # headers themselves. Otherwise all scripts would have to overwrite the
@@ -60,6 +80,114 @@ AddEncoding gzip svgz
 <IfModule mod_rewrite.c>
   RewriteEngine on
 
+  # Return a 403 for autodiscover requests.
+  RewriteCond %{REQUEST_URI} /autodiscover/autodiscover.xml [NC]
+  RewriteRule ^ - [F,L]
+
+  # Redirect http(s)://www.domain.com to https://domain.com.
+  RewriteCond %{HTTP_HOST} !\.acquia-sites\.com [NC]
+  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
+  RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]
+
+  # Redirect all traffic from HTTP to HTTPS.
+  RewriteCond %{HTTP_HOST} !\.acquia-sites\.com [NC]
+  RewriteCond %{HTTPS} off
+  RewriteCond %{HTTP:X-Forwarded-Proto} !https
+  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
+
+  # Redirect legacy stories site for the homepage.
+  RewriteCond %{HTTP_HOST} ^artsci.edu$
+  RewriteRule ^stories(.*)$  https://stories.artsci.edu$1 [R,L]
+
+  # Redirect engineering.artsci.edu/~ to user.engineering.artsci.edu for Engineering
+  RewriteCond %{HTTP_HOST} engineering\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteCond %{REQUEST_FILENAME} !-f
+  RewriteCond %{REQUEST_FILENAME} !-d
+  RewriteCond %{REQUEST_URI} /~(.*)
+  RewriteRule ^(.*)$ https://user.engineering.artsci.edu/$1 [L,R=301]
+
+  # Redirect veterans.org.artsci.edu to veterans.artsci.edu/uiva.
+  RewriteCond %{HTTP_HOST} veterans.org.artsci.edu [NC]
+  RewriteRule ^ https://veterans.artsci.edu/uiva%{REQUEST_URI} [L,R=301]
+
+  # Redirect trans-resources.org.artsci.edu to uihc.org/educational-resources/information-transgender-individuals.
+  RewriteCond %{HTTP_HOST} ^trans-resources\.org\.artsci\.edu$ [NC]
+  RewriteRule ^(.*)$ https://uihc.org/educational-resources/information-transgender-individuals/ [R=301,L]
+
+  # Redirect iconsortium.subst-abuse.artsci.edu to icsa.artsci.edu
+  RewriteCond %{HTTP_HOST} iconsortium\.subst-abuse\.artsci\.edu$ [NC]
+  RewriteRule ^ https://icsa.artsci.edu/ [L,R=301]
+
+  # Redirect www.(cs|math|stat).artsci.edu/~ to homepage.divms.artsci.edu for CS, Math, Stats
+  RewriteCond %{HTTP_HOST} ^(www\.)?(cs|math|stat)\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteCond %{REQUEST_FILENAME} !-f
+  RewriteCond %{REQUEST_FILENAME} !-d
+  RewriteCond %{REQUEST_URI} /~(.*)
+  RewriteRule ^(.*)$ http://homepage.divms.artsci.edu/$1 [L,R=301]
+
+  # Redirect physics.artsci.edu/~ to homepage.physics.artsci.edu for Physics and Astronomy
+  RewriteCond %{HTTP_HOST} physics\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteCond %{REQUEST_FILENAME} !-f
+  RewriteCond %{REQUEST_FILENAME} !-d
+  RewriteCond %{REQUEST_URI} /~(.*)
+  RewriteRule ^(.*)$ http://homepage.physics.artsci.edu/$1 [L,R=301]
+
+  # Redirect physics.artsci.edu/itu/* to itu.physics.artsci.edu/* for Physics and Astronomy ITU
+  RewriteCond %{HTTP_HOST} physics\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteCond %{REQUEST_URI} ^/itu/(.*) [NC,OR]
+  RewriteCond %{REQUEST_URI} ^/itu$ [NC]
+  RewriteRule ^itu(.*)$ https://itu.physics.artsci.edu/$1 [L,R=301]
+
+  # Redirect www and writinguniversity.org to writing.artsci.edu.
+  # Preserve path and query.
+  RewriteCond %{HTTP_HOST} ^(www\.|)writinguniversity\.org$ [NC]
+  RewriteRule ^(.*)$ https://writing.artsci.edu/$1 [L,R=301]
+
+  # Redirect www and writinguniversity.artsci.edu to writing.artsci.edu.
+  # Preserve path and query, exclude prod.
+  RewriteCond %{HTTP_HOST} ^(www\.|)writinguniversity\.((stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^(.*)$ https://writing.artsci.edu/$1 [L,R=301]
+
+  # Redirect rules for diversity.artsci.edu.
+  RewriteCond %{HTTP_HOST} diversity\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^johndeerescholars$ https://provost.artsci.edu/johndeerescholars [R=301,L]
+
+  RewriteCond %{HTTP_HOST} diversity\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^programs/student-support/trio-student-support-services$ https://uc.artsci.edu/trio-student-support-services [R=301,L]
+
+  RewriteCond %{HTTP_HOST} diversity\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^report$ https://ocrc.artsci.edu/report [R=301,L]
+
+  RewriteCond %{HTTP_HOST} diversity\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^programs/high-school-hawkeyes/trio-upward-bound$ https://uc.artsci.edu/students/trio-upward-bound [R=301,L]
+
+  RewriteCond %{HTTP_HOST} diversity\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^(.*)$ https://ocrc.artsci.edu/ [R=301,L]
+
+  # Redirect rules for the IIHR.
+  RewriteCond %{HTTP_HOST} iihr\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^igs/geosam/(.*)$ https://igs.iihr.artsci.edu/igs/geosam/$1 [R=301,L]
+
+  RewriteCond %{HTTP_HOST} iihr\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^igs/geocore/(.*)$ https://igs.iihr.artsci.edu/igs/geocore/$1 [R=301,L]
+
+  RewriteCond %{HTTP_HOST} iihr\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^igs/publications/(.*)$ https://igs.iihr.artsci.edu/igs/publications/$1 [R=301,L]
+
+  # Redirect rules for medicine
+  RewriteCond %{HTTP_HOST} ^(www\.)?medicine\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^artsciprotocols/?$ https://artsciprotocols.medicine.artsci.edu [R=301,L]
+
+  RewriteCond %{HTTP_HOST} ^(www\.)?medicine\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^artsciprotocols/content(/.*)?$ https://artsciprotocols.medicine.artsci.edu/protocols$1 [R=301,L]
+
+  RewriteCond %{HTTP_HOST} ^(www\.)?medicine\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^artsciprotocols/(.+)$ https://artsciprotocols.medicine.artsci.edu/protocols/$1 [R=301,L]
+
+  # Redirect opsmanual.artsci.edu to policy.artsci.edu.
+  RewriteCond %{HTTP_HOST} opsmanual\.((prod|stage|dev)\.drupal\.)?artsci\.edu$ [NC]
+  RewriteRule ^(.*)$ https://policy.artsci.edu/$1 [L,R=301]
+
   # Set "protossl" to "s" if we were accessed via https://.  This is used later
   # if you enable "www." stripping or enforcement, in order to ensure that
   # you don't bounce between http and https.
@@ -168,6 +296,10 @@ AddEncoding gzip svgz
       # Force proxies to cache gzipped & non-gzipped css/js files separately.
       Header append Vary Accept-Encoding
     </FilesMatch>
