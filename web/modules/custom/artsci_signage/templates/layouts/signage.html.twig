{#
/**
 * @file
 * Default theme implementation to display a one column layout.
 *
 * Available variables:
 * - content: The content for this layout.
 * - attributes: HTML attributes for the layout <div>.
 *
 * @ingroup themeable
 * @see https://www.drupal.org/docs/8/api/layout-api/how-to-register-layouts
 * @see https://v4-alpha.getbootstrap.com/layout/grid/
 */
#}
{%
  set classes = [
    'bg--black',
    'page__container--full',
  ]
%}

{% set attributes = attributes.addClass(classes) %}
{% include '@atomic_artsci/layouts/layout.html.twig' %}

<div class="signage--empty element--flex-center element--vh">
  {{ attach_library('atomic_artsci/logo') }}
  {% include "@atomic_artsci/artsci/logo.twig" with {
    path: "https://artsci.edu",
    logo_classes: "logo--tab",
  } %}
</div>
