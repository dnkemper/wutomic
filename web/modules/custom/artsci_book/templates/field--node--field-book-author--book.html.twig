{#
/**
 * @file
 * Theme override for the book author field.
 *
 * Displays "About the author(s)" section with rendered person teasers.
 */
#}
{%
  set classes = [
    'field',
    'field--name-' ~ field_name|clean_class,
    'field--type-' ~ field_type|clean_class,
    'field--label-' ~ label_display,
    'book-authors',
  ]
%}

{% if items|length > 0 %}
<div{{ attributes.addClass(classes) }}>
  <h2 class="book-authors__title">{{ author_label }}</h2>
  <div class="book-authors__list">
    {% for item in items %}
      <div class="book-authors__item">
        {{ item.content }}
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}
