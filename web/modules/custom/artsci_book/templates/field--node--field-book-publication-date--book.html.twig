{#
/**
 * @file
 * Theme override for the book publication date field.
 *
 * Displays "Published [Month Year]" format.
 */
#}
{%
  set classes = [
    'field',
    'field--name-' ~ field_name|clean_class,
    'field--type-' ~ field_type|clean_class,
    'book-publication-date',
  ]
%}

{% for item in items %}
  <div{{ attributes.addClass(classes) }}>{{ 'Published'|t }} {{ item.content }}</div>
{% endfor %}
