{#
/**
 * @file
 * Theme override for the book tags field.
 *
 * Displays "TOPICS" heading with tag links.
 */
#}
{%
  set classes = [
    'field',
    'field--name-' ~ field_name|clean_class,
    'field--type-' ~ field_type|clean_class,
    'book-topics',
  ]
%}

{% if items|length > 0 %}
<div{{ attributes.addClass(classes) }}>
  <h3 class="book-topics__title">{{ 'Topics'|t }}</h3>
  <ul class="book-topics__list">
    {% for item in items %}
      <li class="book-topics__item">{{ item.content }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}
