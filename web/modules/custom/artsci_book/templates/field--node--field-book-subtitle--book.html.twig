{#
/**
 * @file
 * Theme override for the book subtitle field.
 *
 * Displays subtitle with appropriate styling.
 */
#}
{%
  set classes = [
    'field',
    'field--name-' ~ field_name|clean_class,
    'book-subtitle',
  ]
%}

{% for item in items %}
  <div{{ attributes.addClass(classes) }}>{{ item.content }}</div>
{% endfor %}
