<?php

/**
 * @file
 * Provides updated book structure for WashU Arts & Sciences.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_help().
 */
function artsci_book_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.artsci_book':
      $filepath = dirname(__FILE__) . '/README.md';
      if (file_exists($filepath)) {
        $readme = file_get_contents($filepath);
      }
      else {
        $filepath = dirname(__FILE__) . '/README.txt';
        if (file_exists($filepath)) {
          $readme = file_get_contents($filepath);
        }
      }
      if (!isset($readme)) {
        return NULL;
      }

      /** @var \Drupal\Core\Extension\ModuleHandler $moduleHandler */
      $moduleHandler = \Drupal::service('module_handler');
      if ($moduleHandler->moduleExists('markdown')) {
        $filters = $moduleHandler->invoke('markdown', 'filter_info');
        $info = $filters['filter_markdown'];

        if (function_exists($info['process callback'])) {
          $output = $info['process callback']($readme, NULL);
        }
        else {
          $output = '<pre>' . $readme . '</pre>';
        }
      }
      else {
        $output = '<pre>' . $readme . '</pre>';
      }

      return $output;
  }
}

/**
 * Implements hook_page_attachments().
 */
function artsci_book_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'artsci_book/artsci_book_styling';
}

/**
 * Implements hook_theme().
 */
function artsci_book_theme($existing, $type, $theme, $path) {
  return [
    'field__node__field_book_publication_date__book' => [
      'render element' => 'content',
      'base hook' => 'field',
      'template' => 'field--node--field-book-publication-date--book',
      'path' => $path . '/templates',
    ],
    'field__node__book_owner__book' => [
      'render element' => 'content',
      'base hook' => 'field',
      'template' => 'field--node--book-owner--book',
      'path' => $path . '/templates',
    ],
    'field__node__book_tags__book' => [
      'render element' => 'content',
      'base hook' => 'field',
      'template' => 'field--node--book-tags--book',
      'path' => $path . '/templates',
    ],
    'field__node__field_book_author__book' => [
      'render element' => 'content',
      'base hook' => 'field',
      'template' => 'field--node--field-book-author--book',
      'path' => $path . '/templates',
    ],
    'field__node__field_book_subtitle__book' => [
      'render element' => 'content',
      'base hook' => 'field',
      'template' => 'field--node--field-book-subtitle--book',
      'path' => $path . '/templates',
    ],
    'field__node__field_book_links__book' => [
      'render element' => 'content',
      'base hook' => 'field',
      'template' => 'field--node--field-book-links--book',
      'path' => $path . '/templates',
    ],
    'node__person__book_author' => [
      'render element' => 'content',
      'base hook' => 'node',
      'template' => 'node--person--book-author',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_theme_registry_alter().
 */
function artsci_book_theme_registry_alter(&$theme_registry) {
  /** @var \Drupal\Core\Extension\ExtensionPathResolver $path_resolver */
  $path_resolver = \Drupal::service('extension.path.resolver');
  $theme_registry['book_navigation']['path'] = $path_resolver->getPath('module', 'artsci_book') . '/templates';
  $theme_registry['book_tree']['path'] = $path_resolver->getPath('module', 'artsci_book') . '/templates';
}

/**
 * Implements hook_preprocess_node() for person nodes in book_author view mode.
 */
function artsci_book_preprocess_node__person__book_author(&$variables) {
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];

  // Get first name for "Learn More About [First Name]" link.
  $first_name = '';
  if ($node->hasField('field_person_first_name') && !$node->get('field_person_first_name')->isEmpty()) {
    $first_name = $node->get('field_person_first_name')->value;
  }
  $variables['first_name'] = $first_name;

  // Get last name.
  $last_name = '';
  if ($node->hasField('field_person_last_name') && !$node->get('field_person_last_name')->isEmpty()) {
    $last_name = $node->get('field_person_last_name')->value;
  }
  $variables['last_name'] = $last_name;

  // Full name for display.
  $variables['full_name'] = trim($first_name . ' ' . $last_name);

  // URL to the person page.
  $variables['person_url'] = $node->toUrl()->toString();

  // Check if person is external (has website but no internal page content).
  $is_external = FALSE;
  if ($node->hasField('field_person_website') && !$node->get('field_person_website')->isEmpty()) {
    $website = $node->get('field_person_website')->first();
    if ($website) {
      $variables['external_url'] = $website->getUrl()->toString();
      // Check if link should go directly to external site.
      if ($node->hasField('field_person_website_link_direct') && $node->get('field_person_website_link_direct')->value) {
        $is_external = TRUE;
      }
    }
  }
  $variables['is_external'] = $is_external;
}

/**
 * Implements hook_preprocess_field() for book author field.
 */
function artsci_book_preprocess_field__node__field_book_author__book(&$variables) {
  // Add "About the author" / "About the authors" label based on count.
  $count = count($variables['items']);
  $variables['author_label'] = $count > 1 ? t('About the authors') : t('About the author');
}
