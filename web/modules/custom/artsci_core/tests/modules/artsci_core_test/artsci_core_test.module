/**
 * Implements hook_mail().
 */
function artsci_core_test_mail($key, &$message, $params) {
  // Simulate a module that only sets a from address with no name.
  // @see: MailTest::testFromNameSetToSiteNameIfEmptyAndNotArtsci.
  $message['from'] = 'foo@bar.com';
}
