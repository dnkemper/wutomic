<?php

/**
 * @file
 * Install tasks.
 */

/**
 * Set new configuration for all MAUI blocks.
 */
function artsci_maui_update_9001() {
  \Drupal::moduleHandler()->loadInclude('artsci', 'install');
  _update_all_blocks_by_plugin_id('artsci_maui_academic_dates', function (&$component, $block) {
    $config = $component->get('configuration');
    $config['items_to_display'] = 10;
    $config['limit_dates'] = FALSE;
    $config['display_more_link'] = FALSE;
    $config['more_link'] = 'https://registrar.artsci.edu/academic-calendar';
    $config['more_text'] = 'View more';
    $component->setConfiguration($config);
  });
}
