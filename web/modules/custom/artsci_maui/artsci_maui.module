<?php

/**
 * @file
 * Primary module hooks for artsci_maui module.
 */

/**
 * Implements hook_preprocess_HOOK().
 */
function artsci_maui_preprocess_block(&$variables) {
  if ($variables['elements']['#plugin_id'] === 'artsci_maui_academic_dates') {
    $variables['attributes']['class'][] = 'list-container list-container--list';
  }
}
