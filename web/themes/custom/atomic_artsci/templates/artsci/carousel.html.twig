{#
/**
 * @file
 * Artsci carousel component — large (3-card fan) and mini (single slide).
 *
 * Variables:
 *   - carousel_id: Unique ID
 *   - carousel_size: 'large' or 'mini'
 *   - pre_title: Optional pre-title
 *   - title: Optional title
 *   - slides: Rendered paragraph items
 *   - slide_count: Number of slides
 *   - pre_title_style: 'red_caps' or 'subtle'
 *   - deco_vline: Decorative line position
 */
#}
{% set carousel_size   = carousel_size|default('large') %}
{% set carousel_id     = carousel_id|default('carousel') %}
{% set slide_count     = slide_count|default(0) %}
{% set pre_title_style = pre_title_style|default('red_caps') %}
{% set deco_vline      = deco_vline|default(null) %}

{% set is_mini = carousel_size == 'mini' %}

{% set carousel_classes = [
  'artsci-carousel',
  is_mini ? 'artsci-carousel--mini' : 'artsci-carousel--large',
]|filter(v => v is not empty) %}

<div class="{{ carousel_classes|join(' ') }}"
     data-artsci-carousel
     data-carousel-size="{{ carousel_size }}"
     id="{{ carousel_id }}">

  {% if not is_mini %}
    {# ===== LARGE CAROUSEL ===== #}

    {% if deco_vline and deco_vline starts with 'top' %}
      <div class="deco-vline deco-vline--top {{ deco_vline == 'top_red' ? 'deco-vline--red' : 'deco-vline--black' }}" aria-hidden="true"></div>
    {% endif %}

    <div class="artsci-carousel__shield" aria-hidden="true"></div>

    {% if pre_title is not empty %}
      <div class="artsci-carousel__pre-title {{ pre_title_style == 'subtle' ? 'pretitle--subtle' : 'pretitle--red-caps' }}">
        {{ pre_title }}
      </div>
    {% endif %}

    {% if title is not empty %}
      <h2 class="artsci-carousel__title headline headline--serif">{{ title }}</h2>
    {% endif %}

    <div class="artsci-carousel__track" data-carousel-track aria-live="polite">
      {% block slides %}
        {{ slides }}
      {% endblock %}
    </div>

    {% if slide_count > 1 %}
      <div class="artsci-carousel__nav">
        <button class="artsci-carousel__arrow artsci-carousel__arrow--prev" data-carousel-prev aria-label="Previous slide" aria-controls="{{ carousel_id }}">
          <span class="fas fa-chevron-left" aria-hidden="true"></span>
        </button>
        <button class="artsci-carousel__arrow artsci-carousel__arrow--next" data-carousel-next aria-label="Next slide" aria-controls="{{ carousel_id }}">
          <span class="fas fa-chevron-right" aria-hidden="true"></span>
        </button>
      </div>
    {% endif %}

    {% if deco_vline and deco_vline starts with 'bottom' %}
      <div class="deco-vline deco-vline--bottom {{ deco_vline == 'bottom_red' ? 'deco-vline--red' : 'deco-vline--black' }}" aria-hidden="true"></div>
    {% endif %}

  {% else %}
    {# ===== MINI CAROUSEL ===== #}

    <div class="artsci-carousel__viewport" data-carousel-track aria-live="polite">
      {% block mini_slides %}
        {{ slides }}
      {% endblock %}
    </div>

    {% if slide_count > 1 %}
      <div class="artsci-carousel__nav">
        <button class="artsci-carousel__arrow artsci-carousel__arrow--prev" data-carousel-prev aria-label="Previous" aria-controls="{{ carousel_id }}">
          <span class="fas fa-chevron-left" aria-hidden="true"></span>
        </button>
        <button class="artsci-carousel__arrow artsci-carousel__arrow--next" data-carousel-next aria-label="Next" aria-controls="{{ carousel_id }}">
          <span class="fas fa-chevron-right" aria-hidden="true"></span>
        </button>
      </div>
    {% endif %}

  {% endif %}
</div>
