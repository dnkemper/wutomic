{#
/**
 * @file
 * Artsci stories carousel — horizontal scrolling portrait cards.
 *
 * Uses data-artsci-carousel + data-carousel-size="stories" so the
 * unified carousel JS handles arrow navigation and scroll tracking.
 *
 * Variables:
 *   - carousel_id, pre_title, title, description, slides
 *   - pre_title_style
 */
#}
{% set carousel_id     = carousel_id|default('stories-carousel') %}
{% set pre_title_style = pre_title_style|default('red_caps') %}

<div class="stories-carousel"
     data-artsci-carousel
     data-carousel-size="stories"
     id="{{ carousel_id }}">

  <div class="stories-carousel__layout">

    {# Left text column #}
    <div class="stories-carousel__text">
      {% if pre_title is defined and pre_title is not empty %}
        <div class="stories-carousel__pre-title {{ pre_title_style == 'subtle' ? 'pretitle--subtle' : 'pretitle--red-caps' }}">
          {{ pre_title }}
        </div>
      {% endif %}

      {% if title is defined and title is not empty %}
        <h2 class="stories-carousel__title">{{ title }}</h2>
      {% endif %}

      {% if description is defined and description is not empty %}
        <div class="stories-carousel__description">{{ description }}</div>
      {% endif %}

      <div class="stories-carousel__nav">
        <button class="stories-carousel__arrow stories-carousel__arrow--prev"
                data-carousel-prev
                aria-label="Scroll left"
                aria-controls="{{ carousel_id }}-track">
          <span class="fas fa-chevron-left" aria-hidden="true"></span>
        </button>
        <button class="stories-carousel__arrow stories-carousel__arrow--next"
                data-carousel-next
                aria-label="Scroll right"
                aria-controls="{{ carousel_id }}-track">
          <span class="fas fa-chevron-right" aria-hidden="true"></span>
        </button>
      </div>
    </div>

    {# Scrollable card track #}
    <div class="stories-carousel__track" data-carousel-track id="{{ carousel_id }}-track">
      {% block story_slides %}
        {{ slides }}
      {% endblock %}
    </div>

  </div>
</div>
