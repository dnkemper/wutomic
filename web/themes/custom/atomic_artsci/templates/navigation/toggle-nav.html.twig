{{ attach_library('atomic_artsci/toggle-nav') }}

{% if page.primary_menu|render|striptags|trim is not empty %}
  <div class="o-canvas__group">
    <div class="o-canvas__wrapper">
      {% include '@atomic_artsci/navigation/toggle-nav--bttn.twig' %}
      {% embed '@atomic_artsci/navigation/toggle-nav--drawer.html.twig' %}
        {% block drawer %}
          {{ page.primary_menu }}
        {% endblock %}
      {% endembed %}
    </div>
  </div>
{% endif %}
