        "drupal/layout_builder_browser": "^1.8",
        "drupal/layout_builder_component_attributes": "^2.2",
        "drupal/layout_builder_limit": "^1.0@beta",
        "drupal/layout_builder_lock": "^2.0@RC",
        "drupal/layout_builder_modal": "^2.0",
