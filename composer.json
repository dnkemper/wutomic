        "drupal/paragraphs": "^1.18",
        "drupal/pathauto": "^1.13",
        "drupal/photoswipe": "^5.0",
        "drupal/private_content": "^2.1",
        "drupal/purge": "^3.6.0",
        "drupal/rabbit_hole": "^2.0@beta",
        "drupal/rebuild_cache_access": "^1.12",
        "drupal/redirect": "^1.10",
        "drupal/replicate": "^1.3",
        "drupal/replicate_actions": "^1.8",
        "drupal/replicate_ui": "1.x-dev@dev",
        "drupal/responsive_table_filter": "^2.1",
        "drupal/robotstxt": "^1.2",
        "drupal/scheduler": "^2.2",
        "drupal/scheduler_content_moderation_integration": "^3.0",
        "drupal/schema_metatag": "^3.0",
        "drupal/search_api": "^1.40",
        "drupal/search_api_autocomplete": "^1.11",
        "drupal/simple_sitemap": "^4.2",
        "drupal/simplei": "^3.0",
        "drupal/smart_date": "^4.2",
        "drupal/smart_trim": "^2.0",
        "drupal/stage_file_proxy": "^3.1",
        "drupal/superfish": "^1.8",
        "drupal/symfony_mailer": "^1.3",
        "drupal/table_header_scope_attribute": "^2.0",
        "drupal/theme_permission": "^2.0",
        "drupal/token": "^1.16",
        "drupal/tour": "^2.0",
        "drupal/turnstile": "^1.1",
        "drupal/tvi": "^2.0",
        "drupal/twig_tweak": "^3.4",
        "drupal/twig_vardumper": "^3.1",
        "drupal/twigsuggest": "^2.0@RC",
        "drupal/views_bulk_operations": "^4.3",
        "drupal/views_core_entity_reference": "^1.0@alpha",
        "drupal/views_custom_cache_tag": "^1.3",
        "drupal/views_data_export": "^1.6",
        "drupal/views_tree": "^3.0",
        "drupal/webform": "^6.3@beta",
        "drupal/weight": "^3.2",
        "drupal/workbench_email": "^3.0",
        "drush/drush": "^13.7",
        "npm-asset/photoswipe-dynamic-caption-plugin": "^1.2",
        "npm-asset/slick-carousel": "^1.8",
        "oomphinc/composer-installers-extender": "^2.0",
        "pantheon-systems/drupal-integrations": "^11.2",
        "pantheon-upstreams/upstream-configuration": "dev-main"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "classmap": ["upstream-configuration/scripts/ComposerScripts.php"],
        "psr-4": {
            "Drush\\Commands\\": "drush/commands/"
        }
    },
    "scripts": {
        "post-drupal-scaffold-cmd": [
        "patch -p1 < patches/development_services.patch"
        ],
        "drupal-scaffold": "DrupalComposer\\DrupalScaffold\\Plugin::scaffold",
        "nuke": [
        "rm -rf vendor web/core web/modules/contrib web/profiles/contrib web/themes/contrib",
        "@composer clearcache --ansi",
        "@composer install --ansi"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-recipe-unpack": true,
            "oomphinc/composer-installers-extender": true,
            "php-http/discovery": true,
            "php-tuf/composer-integration": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "enable-patching": true,
        "composer-exit-on-patch-failure": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "patches": {
            "drupal/address": {
                "Return type declaration for extension of diff plugin base": "https://www.drupal.org/files/issues/2024-07-10/diff-module-support-3460590-2.patch"
            },
            "drupal/book": {
                "Book module does not check access for unpublished content": "https://git.drupalcode.org/project/book/-/merge_requests/168.diff"
            },
            "drupal/ckeditor": {
                "Changing an existing embedded media's alignment or alt data attributes does not get saved with CKEditor": "https://www.drupal.org/files/issues/2023-01-03/3330723-3.patch"
            },
            "drupal/core": {
                "[2985199] Extensions in Multisite Directories Not Registered When Rebuilding Cache": "https://www.drupal.org/files/issues/2025-12-23/2985199-100.patch",
                "[2942975] Expose Layout Builder data to REST and JSON:API": "https://www.drupal.org/files/issues/2026-01-06/core-2942975-285-core-layout-entity-normalizers.patch",
                "[2605218] Views Block Display skips preBlockBuild() call on ajax rebuild": "https://www.drupal.org/files/issues/2026-01-15/2605218-143.diff",
                "[3015152] Support third party settings for components within a section": "https://www.drupal.org/files/issues/2025-09-29/3015152-support_third_party_settings_11.2.4_without_tests.patch",
                "[3047022] Layout builder fails to assign inline block access dependencies for the overrides section storage on entities with pending revisions": "patches/core-3047022.patch",
                "[3160785] Fix LB contextual links after dragging block to new section": "https://www.drupal.org/files/issues/2023-06-09/3160785-uuid_0.patch",
                "[3163299] Ajax exposed filters not working for multiple instances of the same Views block placed on one page": "patches/core-3163299.patch",
                "PHP8.1 deprecation: str_replace()": "https://www.drupal.org/files/issues/2023-06-07/3294680-22.patch",
                "[3030154] layout_builder__layout_section column hitting database limit": "https://www.drupal.org/files/issues/2021-10-11/3030154-44.patch",
                "[3359465] Layout builder off-canvas positioning problem when resizing browser ": "https://www.drupal.org/files/issues/2023-07-19/3359465-8.patch",
                "[2755791] Ajax error ajax.$form.ajaxSubmit() is not a function": "patches/core-2755791.patch",
                "[3310075] Toolbar js errors when you remove the administration menu": "patches/core-3310075.patch",
                "[3498100] Duplicate summary on vertical tabs" : "https://www.drupal.org/files/issues/2025-01-08/3498100-2-core-duplicate-summary-on-vertical-tabs.patch"
            },
            "drupal/default_content": {
                "Add a Normalizer and Denormalizer to support Layout Builder": "https://www.drupal.org/files/issues/2022-12-06/default_content-3160146-53.patch",
                "Predictable order of content import": "https://www.drupal.org/files/issues/2020-10-08/3175870.patch"
            },
            "drupal/draggableviews": {
                "Completely hide the weights field for anonymous users": "https://www.drupal.org/files/issues/2021-08-31/3229357-7.patch"
            },
            "drupal/entity_reference_revisions": {
                "[3201705] Orphan purger : if entity's parent is invalid (NULL), dig deeper": "patches/3201705.patch"
            },
            "drupal/field_delimiter": {
                "Doesn't work in layout builder": "https://www.drupal.org/files/issues/2020-04-08/field_delimiter-3099580-7.patch"
            },
            "drupal/fontawesome": {
                "[3380581] Iconpicker does not render classes appropriately": "https://www.drupal.org/files/issues/2025-03-06/iconpicker-does-not-render_3380581_11.patch",
                "[3274028] CKEditor 5 compatibility": "patches/3274028-fontawesome.patch"
            },
            "drupal/fragments": {
                "remove_views_data_type": "https://www.drupal.org/files/issues/2022-08-24/3305851-remove_views_data_type-6.patch"
            },
            "drupal/fullcalendar_view": {
                "only_rebuild_on_view_change": "patches/fullcalendar_only_rebuild_on_view_change.patch"
            },
            "drupal/layout_builder_styles": {
                "Section dependency on layout plugin configuration form": "https://www.drupal.org/files/issues/2019-08-23/layout_builder_styles-3062261-%2310.patch",
                "Some styles get added multiple times": "https://www.drupal.org/files/issues/2023-02-14/3341740-3.patch",
                "Allow radio buttons for single-select group form type": "patches/lbs_3290930.patch"
            },
            "drupal/linkit": {
                "Add Webform Matcher": "https://www.drupal.org/files/issues/2023-06-13/linkit-webform-matcher-2946234-36.patch",
                "[3223781]Add Support for <nolink>": "patches/3223781.patch"

            },
            "drupal/paragraphs": {
                "find the correct revision ID of the parent": "https://www.drupal.org/files/issues/2020-07-08/access-controll-issue-3090200-22.patch"
            },
            "drupal/rabbit_hole": {
                "Issue with .install file.": "patches/rabbit_hole_install_fix.patch"
            },
            "drupal/redirect": {
                "Match redirect": "https://www.drupal.org/files/issues/2020-04-13/redirect-n2831605-31.patch"
            },
            "drupal/replicate": {
                "Replicate components in the proper order.": "patches/3392959.patch"
            },
            "drupal/scheduler_content_moderation_integration": {
                "Set a default value in the publish / unpublish state dropdowns": "https://www.drupal.org/files/issues/2023-04-19/3270462-25.patch"
            },
            "drupal/superfish": {
                "Menu renders empty <ul></ul> if it only contains menu link(s) that are not enabled": "patches/superfish-3548286.patch"
            }
        },
        "installer-types": [
            "bower-asset",
            "npm-asset"
        ],
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/modules/artsci/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library",
                "type:bower-asset",
                "type:npm-asset"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "./web"
            },
            "file-mapping": {
                "[web-root]/robots.txt": false,
                "[web-root]/sites/default/default.services.yml": {
                    "mode": "replace",
                    "path": "web/core/assets/scaffold/files/default.services.yml",
                    "overwrite": false
                },
                "[web-root]/sites/default/default.settings.php": {
                    "mode": "replace",
                    "path": "web/core/assets/scaffold/files/default.settings.php",
                    "overwrite": false
                }
            }
        }
    },
    "require-dev": {
        "drupal/devel": "^5.5"
    }
}
