#!/bin/bash

## Description: Sync wustl-johnmaxwulfing site from Pantheon to local DDEV
## Usage: wulfing [environment]
## Example: ddev wulfing
## Example: ddev wulfing test
## Example: ddev wulfing live

NOW=$(TZ=America/Chicago date +"%Y-%m-%d-%H-%M-%S")
red=$(tput setaf 1)$(tput bold)
green=$(tput setaf 2)
yellow=$(tput setaf 3)$(tput bold)
blue=$(tput setaf 4)
magenta=$(tput setaf 5)$(tput bold)
NC=$(tput sgr0)

echo -e "\n\n${yellow}>>>>>${NC} ${magenta}${NOW}${NC} ${green}Wulfing Pantheon Sync${NC} ${yellow}<<<<<${NC}\n"

# Pantheon site configuration
SITE_NAME="wustl-johnmaxwulfing"
PANTHEON_ENV="${1:-test}"
SETTINGS_FILE="web/sites/default/settings.php"

# Map environment name
map_to_pantheon_env() {
  case $1 in
    dev|1) echo "dev";;
    stage|test|2) echo "test";;
    prod|live|3) echo "live";;
    *) echo "$1";;
  esac
}

PANTHEON_ENV=$(map_to_pantheon_env "$PANTHEON_ENV")

if [[ ! "$PANTHEON_ENV" =~ ^(dev|test|live)$ ]]; then
  echo "${red}Invalid environment: $PANTHEON_ENV${NC}"
  echo "Use: dev, test, or live"
  exit 1
fi

# Verify Terminus authentication
echo -e "${blue}Verifying Terminus authentication...${NC}"
if ! terminus auth:whoami &>/dev/null; then
  echo "${red}Not authenticated with Terminus. Please run: terminus auth:login${NC}"
  exit 1
fi

# Verify the site exists on Pantheon
echo -e "${blue}Verifying site exists on Pantheon...${NC}"
if ! terminus site:info "$SITE_NAME" &>/dev/null; then
  echo "${red}Site '$SITE_NAME' not found on Pantheon.${NC}"
  exit 1
fi

# Confirm selections
echo ""
echo "${yellow}========================================${NC}"
echo "${blue}Site:${NC} $SITE_NAME"
echo "${blue}Environment:${NC} $PANTHEON_ENV"
echo "${yellow}========================================${NC}"
echo ""
read -p "Continue with sync? (Y/N): " confirm
if [[ ! $confirm =~ ^[Yy]$ ]]; then
  echo "${yellow}Sync cancelled.${NC}"
  exit 0
fi

# Enable config splits in settings.php (cross-platform sed)
if [ -f "$SETTINGS_FILE" ]; then
  echo -e "${blue}Enabling config_split settings in settings.php...${NC}"
  # Use perl for cross-platform compatibility (works on both macOS and Linux)
  perl -i -pe "s/\\$config\['config_split\.config_split\.coin'\]\['status'\] = FALSE;/\\\$config['config_split.config_split.coin']['status'] = TRUE;/g" "$SETTINGS_FILE" 2>/dev/null || \
  sed -i.bak "s/\\\$config\['config_split\.config_split\.coin'\]\['status'\] = FALSE;/\$config['config_split.config_split.coin']['status'] = TRUE;/g" "$SETTINGS_FILE" && rm -f "${SETTINGS_FILE}.bak"
  echo "${green}Config splits enabled (set to TRUE)${NC}"
else
  echo "${yellow}Warning: settings.php not found at $SETTINGS_FILE${NC}"
fi

# Create backup of current database
echo -e "${blue}Backing up current database to $SITE_NAME-sync-backup-$NOW.sql${NC}"
ddev drush sql-dump > "$SITE_NAME-sync-backup-$NOW.sql"

# Stream database import (faster than download + extract + import)
echo -e "${blue}Downloading database from Pantheon...${NC}"
DB_BACKUP_URL=$(terminus backup:get "$SITE_NAME.$PANTHEON_ENV" --element=db)

if [ -z "$DB_BACKUP_URL" ]; then
  echo "${red}Failed to get database backup URL${NC}"
  echo "${yellow}Try creating a backup first: terminus backup:create $SITE_NAME.$PANTHEON_ENV --element=db${NC}"
  exit 1
fi

echo -e "${blue}Dropping local database${NC}"
ddev drush sql-drop -y

echo -e "${blue}Streaming and importing database${NC}"
if curl -L "$DB_BACKUP_URL" | gunzip | ddev drush sql-cli; then
  echo -e "${green}Database imported successfully${NC}"
else
  echo "${red}Database import failed${NC}"
  exit 1
fi

# Sync files from Pantheon
echo -e "${blue}Syncing files from Pantheon...${NC}"
FILES_BACKUP_URL=$(terminus backup:get "$SITE_NAME.$PANTHEON_ENV" --element=files)

if [ -z "$FILES_BACKUP_URL" ]; then
  echo "${yellow}Warning: Could not get files backup URL. Skipping file sync.${NC}"
else
  echo -e "${blue}Downloading files backup...${NC}"
  curl -L "$FILES_BACKUP_URL" -o "$SITE_NAME-pantheon-files-$NOW.tar.gz"

  mkdir -p "web/sites/default/files"

  echo -e "${blue}Extracting files to web/sites/default/files/...${NC}"
  tar -xzf "$SITE_NAME-pantheon-files-$NOW.tar.gz" --strip-components=1 -C "web/sites/default/files/" 2>/dev/null || \
  tar -xzf "$SITE_NAME-pantheon-files-$NOW.tar.gz" -C "web/sites/default/files/" 2>/dev/null

  rm "$SITE_NAME-pantheon-files-$NOW.tar.gz"
  echo -e "${green}Files synced successfully${NC}"
fi

# Purge field data before config import (needed for Wulfing migrations)
echo -e "${blue}Purging field data...${NC}"
ddev drush php-eval 'field_purge_batch(1000);' 2>/dev/null || echo "${yellow}Field purge completed with warnings${NC}"

# Run database updates
echo -e "${blue}Running database updates${NC}"
ddev drush updb --yes

# Install composer dependencies (NOT update - just install what's locked)
echo -e "${blue}Installing Composer dependencies${NC}"
ddev composer install --no-interaction

# Enable config splits for Wulfing
echo -e "${blue}Enabling Wulfing config splits...${NC}"

if ddev drush pm:list --status=enabled --format=list | grep -q "config_split"; then
  # Enable coin split
  if ddev drush config:get config_split.config_split.coin &>/dev/null; then
    echo -e "${blue}Enabling coin config split...${NC}"
    ddev drush config:set config_split.config_split.coin status TRUE -y
  fi

  # Activate local split if it exists
  if ddev drush config:get config_split.config_split.local &>/dev/null; then
    echo -e "${blue}Activating local config split...${NC}"
    ddev drush config-split:activate local --yes 2>/dev/null || ddev drush config:set config_split.config_split.local status TRUE -y
  fi
else
  echo "${yellow}Config Split module not enabled, skipping split configuration${NC}"
fi

# Import configuration
echo -e "${blue}Importing configuration${NC}"
if ! ddev drush cim --yes; then
  echo "${yellow}Config import had errors, but continuing...${NC}"
fi

# Import config splits if available
if ddev drush pm:list --status=enabled --format=list | grep -q "config_split"; then
  echo -e "${blue}Importing config splits${NC}"
  ddev drush config-split:import -y 2>/dev/null || echo "${yellow}Config split import completed with warnings${NC}"
fi

# Enable development settings
if ddev help dev-settings &>/dev/null 2>&1; then
  echo -e "${blue}Enabling development settings${NC}"
  ddev dev-settings
fi

# Clear cache
echo -e "${blue}Clearing Drupal cache${NC}"
ddev drush cr

# Generate one-time login link
echo -e "${blue}Generating login link${NC}"
ddev drush uli

echo ""
echo "${green}========================================${NC}"
echo "${green}Wulfing sync completed successfully!${NC}"
echo "${green}========================================${NC}"
echo ""
echo "${yellow}Database backup saved to:${NC} $SITE_NAME-sync-backup-$NOW.sql"
echo "${yellow}Synced from:${NC} $SITE_NAME.$PANTHEON_ENV"
echo ""
echo "${blue}Active config splits:${NC}"
ddev drush config:status config_split.config_split.* 2>/dev/null | grep "config_split" || echo "  (Config splits not configured)"
echo ""
