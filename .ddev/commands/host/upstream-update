#!/bin/bash

## Description: Apply upstream updates to a single Pantheon site and optionally deploy
## Usage: upstream-update [site-name] [flags]
## Example: ddev upstream-update wustl-it
## Example: ddev upstream-update it --deploy-test
## Example: ddev upstream-update it --deploy-live
## Example: ddev upstream-update (interactive)

red=$(tput setaf 1)$(tput bold)
green=$(tput setaf 2)
yellow=$(tput setaf 3)$(tput bold)
blue=$(tput setaf 4)
magenta=$(tput setaf 5)$(tput bold)
NC=$(tput sgr0)

NOW=$(TZ=America/Chicago date +"%Y-%m-%d-%H-%M-%S")

echo -e "\n\n${yellow}>>>>>${NC} ${magenta}${NOW}${NC} ${green}Upstream Update${NC} ${yellow}<<<<<${NC}\n"

# Defaults
DEPLOY_TEST=false
DEPLOY_LIVE=false

# Normalize site name
normalize_site_name() {
  local site=$1
  if [[ $site == wustl-* ]]; then
    echo "$site"
  else
    echo "wustl-$site"
  fi
}

# Run drush cim only if there are pending config changes
run_cim_if_needed() {
  local site=$1
  local env=$2

  echo -e "${blue}Checking for pending config changes on ${env}...${NC}"
  CIM_STATUS=$(terminus drush "${site}.${env}" -- cst 2>&1)

  if echo "$CIM_STATUS" | grep -qi "update\|create\|delete"; then
    echo -e "${yellow}Config changes detected, importing...${NC}"
    if terminus drush "${site}.${env}" -- cim -y 2>&1; then
      echo -e "${green}✅ Config imported on ${env}${NC}"
      terminus drush "${site}.${env}" -- cr 2>&1
      return 0
    else
      echo -e "${red}❌ Config import failed on ${env}${NC}"
      return 1
    fi
  else
    echo -e "${green}No config changes to import on ${env}${NC}"
    return 0
  fi
}

# Parse flags
POSITIONAL_ARGS=()
while [[ "$#" -gt 0 ]]; do
  case $1 in
    --deploy-test) DEPLOY_TEST=true; shift ;;
    --deploy-live) DEPLOY_LIVE=true; DEPLOY_TEST=true; shift ;;
    *) POSITIONAL_ARGS+=("$1"); shift ;;
  esac
done
set -- "${POSITIONAL_ARGS[@]}"

# Get site name
if [ -z "$1" ]; then
  echo "${blue}Fetching your Pantheon sites...${NC}"
  sites=($(terminus site:list --format=list --field=name 2>/dev/null | grep "^wustl-" | sort))

  if [ ${#sites[@]} -eq 0 ]; then
    echo "${red}No Pantheon sites found.${NC}"
    exit 1
  fi

  echo ""
  echo "${green}Available Pantheon sites:${NC}"
  PS3="Select the site: "
  select site in "${sites[@]}"; do
    if [[ -n "$site" ]]; then
      SITE_NAME="$site"
      break
    fi
  done
else
  SITE_NAME=$(normalize_site_name "$1")
fi

# Verify Terminus authentication
echo -e "${blue}Verifying Terminus authentication...${NC}"
if ! terminus auth:whoami &>/dev/null; then
  echo "${red}Not authenticated with Terminus. Please run: terminus auth:login${NC}"
  exit 1
fi

# Check for available updates
echo -e "${blue}Checking for upstream updates on ${SITE_NAME}...${NC}"
UPDATES=$(terminus upstream:updates:list "${SITE_NAME}.dev" 2>&1)

if echo "$UPDATES" | grep -qi "no updates\|No available updates"; then
  echo "${green}✓ ${SITE_NAME} is already up to date — no upstream updates available.${NC}"
  exit 0
fi

# Show what's available
echo ""
echo "${yellow}Available upstream updates:${NC}"
echo "$UPDATES"
echo ""

# Confirm
echo "${yellow}========================================${NC}"
echo "${blue}Site:${NC} $SITE_NAME"
echo "${blue}Action:${NC} Apply upstream updates to dev"
if [ "$DEPLOY_TEST" = true ]; then
  echo "${blue}Then:${NC} Deploy dev → test + run updb, cim, cr"
fi
if [ "$DEPLOY_LIVE" = true ]; then
  echo "${blue}Then:${NC} Deploy test → live + run updb, cim, cr"
fi
echo "${yellow}========================================${NC}"
echo ""

# Apply upstream updates to dev
echo -e "\n${blue}Applying upstream updates to ${SITE_NAME}.dev...${NC}"
if terminus upstream:updates:apply "${SITE_NAME}.dev" --accept-upstream --updatedb; then
  echo "${green}✅ Upstream updates applied to dev${NC}"
else
  echo "${red}❌ Failed to apply upstream updates${NC}"
  exit 1
fi

# Deploy to test
if [ "$DEPLOY_TEST" = true ]; then
  echo -e "\n${blue}Deploying dev → test on ${SITE_NAME}...${NC}"
  if terminus env:deploy "${SITE_NAME}.test" --cc --updatedb --note="Upstream update ${NOW}"; then
    echo "${green}✅ Deployed to test${NC}"

    # Run cim on test if needed
    run_cim_if_needed "$SITE_NAME" "test"
  else
    echo "${red}❌ Failed to deploy to test${NC}"
    exit 1
  fi
fi

# Deploy to live
if [ "$DEPLOY_LIVE" = true ]; then
  echo ""
  echo "${red}⚠️  About to deploy to PRODUCTION (live)${NC}"
  read -p "Type 'DEPLOY' to confirm: " live_confirm
  if [[ "$live_confirm" != "DEPLOY" ]]; then
    echo "${yellow}Live deployment cancelled. Dev and test were still updated.${NC}"
    exit 0
  fi

  echo -e "\n${blue}Deploying test → live on ${SITE_NAME}...${NC}"
  if terminus env:deploy "${SITE_NAME}.live" --cc --updatedb --note="Upstream update ${NOW}"; then
    echo "${green}✅ Deployed to live${NC}"

    # Run cim on live if needed
    run_cim_if_needed "$SITE_NAME" "live"
  else
    echo "${red}❌ Failed to deploy to live${NC}"
    exit 1
  fi
fi

echo ""
echo "${green}========================================${NC}"
echo "${green}Upstream update complete for ${SITE_NAME}!${NC}"
echo "${green}========================================${NC}"
echo ""
