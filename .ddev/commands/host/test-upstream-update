#!/bin/bash
## Description: Test upstream update locally WITHOUT applying changes
## Usage: ddev test-upstream-update [site-name|all]
## Example: ddev test-upstream-update wustl-anthropology
## Example: ddev test-upstream-update all

SITE=$1
UPSTREAM_BRANCH="master"  # Change to "main" if your upstream uses main
LOG_DIR="./.ddev/upstream-test-logs"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
TEST_BRANCH="test-upstream-${TIMESTAMP}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

mkdir -p "$LOG_DIR"

print_usage() {
    echo "Usage: ddev test-upstream-update [site-name|all]"
    echo ""
    echo "This previews upstream changes WITHOUT modifying your working branch."
    echo ""
    echo "Options:"
    echo "  site-name  - Test upstream update for a specific site"
    echo "  all        - Test upstream update for all sites in sites.php"
    echo ""
    echo "Examples:"
    echo "  ddev test-upstream-update wustl-anthropology"
    echo "  ddev test-upstream-update all"
    exit 1
}

# Function to get all site names from sites.php
get_all_sites() {
    if [ -f "web/sites/sites.php" ]; then
        grep -oP "'\K[^']+(?='.*=>)" web/sites/sites.php | grep -v "^#" | sort -u
    else
        echo -e "${RED}Error: web/sites/sites.php not found${NC}"
        exit 1
    fi
}

# Function to test a single site
test_site() {
    local site_name=$1
    local log_file="$LOG_DIR/${site_name}-${TIMESTAMP}.log"

    echo -e "${BLUE}=========================================${NC}"
    echo -e "${BLUE}Testing: $site_name${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo "Log file: $log_file"

    # Check if site directory exists
    if [ ! -d "web/sites/$site_name" ]; then
        echo -e "${RED}✗ Site directory web/sites/$site_name not found${NC}" | tee -a "$log_file"
        return 1
    fi

    echo -e "\n${YELLOW}Fetching upstream...${NC}" | tee -a "$log_file"
    if ! git fetch upstream 2>&1 | tee -a "$log_file"; then
        echo -e "${RED}✗ Failed to fetch from upstream${NC}" | tee -a "$log_file"
        return 1
    fi

    echo -e "\n${YELLOW}Checking for merge conflicts...${NC}" | tee -a "$log_file"

    MERGE_BASE=$(git merge-base HEAD upstream/$UPSTREAM_BRANCH 2>/dev/null)
    if [ -z "$MERGE_BASE" ]; then
        echo -e "${RED}✗ Could not determine merge base. Are HEAD and upstream/$UPSTREAM_BRANCH related?${NC}" | tee -a "$log_file"
        return 1
    fi

    MERGE_RESULT=$(git merge-tree $MERGE_BASE HEAD upstream/$UPSTREAM_BRANCH 2>&1)

    if echo "$MERGE_RESULT" | grep -q "changed in both"; then
        echo -e "${RED}✗ Merge conflicts detected (preview only):${NC}" | tee -a "$log_file"
        echo "$MERGE_RESULT" | grep -A 5 "changed in both" | tee -a "$log_file"
        HAS_CONFLICTS=true
    else
        echo -e "${GREEN}✓ No merge conflicts detected${NC}" | tee -a "$log_file"
        HAS_CONFLICTS=false
    fi

    echo -e "\n${YELLOW}Files that would be modified:${NC}" | tee -a "$log_file"
    git diff --name-status HEAD upstream/$UPSTREAM_BRANCH | tee -a "$log_file"

    echo -e "\n${YELLOW}Summary of changes:${NC}" | tee -a "$log_file"
    ADDED=$(git diff --name-status HEAD upstream/$UPSTREAM_BRANCH | grep "^A" | wc -l)
    MODIFIED=$(git diff --name-status HEAD upstream/$UPSTREAM_BRANCH | grep "^M" | wc -l)
    DELETED=$(git diff --name-status HEAD upstream/$UPSTREAM_BRANCH | grep "^D" | wc -l)

    echo "  Files added: $ADDED" | tee -a "$log_file"
    echo "  Files modified: $MODIFIED" | tee -a "$log_file"
    echo "  Files deleted: $DELETED" | tee -a "$log_file"

    echo -e "\n${YELLOW}Upstream commits that would be merged:${NC}" | tee -a "$log_file"
    git log --oneline HEAD..upstream/$UPSTREAM_BRANCH | tee -a "$log_file"

    echo -e "\n${YELLOW}Checking for database update hooks...${NC}" | tee -a "$log_file"
    if git diff HEAD upstream/$UPSTREAM_BRANCH | grep -q "function.*_update_[0-9]"; then
        echo -e "${YELLOW}⚠ Database update hooks detected${NC}" | tee -a "$log_file"
        git diff HEAD upstream/$UPSTREAM_BRANCH | grep -B 2 "function.*_update_[0-9]" | tee -a "$log_file"
        HAS_UPDATES=true
    else
        echo "No database update hooks found" | tee -a "$log_file"
        HAS_UPDATES=false
    fi

    echo -e "\n${YELLOW}Checking for configuration changes...${NC}" | tee -a "$log_file"
    if git diff --name-status HEAD upstream/$UPSTREAM_BRANCH | grep -q "config/"; then
        echo -e "${YELLOW}⚠ Configuration files would change:${NC}" | tee -a "$log_file"
        git diff --name-status HEAD upstream/$UPSTREAM_BRANCH | grep "config/" | tee -a "$log_file"
        HAS_CONFIG_CHANGES=true
    else
        echo "No configuration changes" | tee -a "$log_file"
        HAS_CONFIG_CHANGES=false
    fi

    # Summary
    echo -e "\n${BLUE}=========================================${NC}"
    echo -e "${BLUE}Test Summary for $site_name:${NC}"
    echo -e "${BLUE}=========================================${NC}"

    if [ "$HAS_CONFLICTS" = true ]; then
        echo -e "${RED}⚠ CONFLICTS: Manual merge required${NC}"
    else
        echo -e "${GREEN}✓ Clean merge possible${NC}"
    fi

    if [ "$HAS_UPDATES" = true ]; then
        echo -e "${YELLOW}⚠ Database updates required after merge${NC}"
    fi

    if [ "$HAS_CONFIG_CHANGES" = true ]; then
        echo -e "${YELLOW}⚠ Configuration changes detected${NC}"
    fi

    echo ""
    echo "Full log saved to: $log_file"
    echo ""

    return 0
}

# Main execution
if [ -z "$SITE" ]; then
    print_usage
fi

# Check that git upstream remote exists
if ! git remote | grep -q "^upstream$"; then
    echo -e "${RED}Error: No 'upstream' git remote found.${NC}"
    echo -e "${YELLOW}Add it with: git remote add upstream <your-upstream-repo-url>${NC}"
    echo -e "${YELLOW}Example: git remote add upstream git@github.com:your-org/upstream-repo.git${NC}"
    exit 1
fi

# Save original branch
ORIGINAL_BRANCH=$(git branch --show-current)

echo -e "${BLUE}=========================================${NC}"
echo -e "${BLUE}UPSTREAM UPDATE TEST (Read-only)${NC}"
echo -e "${BLUE}=========================================${NC}"
echo "Your working branch will NOT be modified"
echo "Original branch: $ORIGINAL_BRANCH"
echo ""

if [ "$SITE" = "all" ]; then
    echo -e "${YELLOW}Testing upstream updates for ALL sites...${NC}"
    echo ""

    SITES=($(get_all_sites))

    if [ ${#SITES[@]} -eq 0 ]; then
        echo -e "${RED}No sites found${NC}"
        exit 1
    fi

    echo "Found ${#SITES[@]} sites:"
    printf '%s\n' "${SITES[@]}"
    echo ""

    SUMMARY_LOG="$LOG_DIR/summary-${TIMESTAMP}.log"
    echo "Upstream Update Test Summary - $(date)" > "$SUMMARY_LOG"
    echo "=========================================" >> "$SUMMARY_LOG"

    CLEAN_COUNT=0
    CONFLICT_COUNT=0

    for site in "${SITES[@]}"; do
        if test_site "$site"; then
            if grep -q "Merge conflicts detected" "$LOG_DIR/${site}-${TIMESTAMP}.log" 2>/dev/null; then
                ((CONFLICT_COUNT++))
                echo "⚠ $site - CONFLICTS DETECTED" >> "$SUMMARY_LOG"
            else
                ((CLEAN_COUNT++))
                echo "✓ $site - CLEAN MERGE" >> "$SUMMARY_LOG"
            fi
        fi
        echo ""
    done

    echo -e "\n${BLUE}=========================================${NC}"
    echo -e "${BLUE}FINAL SUMMARY${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "Clean merges: ${GREEN}$CLEAN_COUNT${NC}"
    echo -e "Conflicts: ${RED}$CONFLICT_COUNT${NC}"
    echo "Summary log: $SUMMARY_LOG"
    echo ""
    cat "$SUMMARY_LOG"
    echo ""
    echo -e "${YELLOW}No changes were made to your working directory.${NC}"

else
    test_site "$SITE"
    echo ""
    echo -e "${YELLOW}No changes were made to your working directory.${NC}"
    echo "To actually apply these changes, you would run:"
    echo "  git fetch upstream"
    echo "  git merge upstream/$UPSTREAM_BRANCH"
fi
